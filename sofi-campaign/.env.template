# SoFi Campaign — API Keys
# Copy this file to .env, fill in all values, then run: source .env

# 1. Get from console.anthropic.com → Settings → API Keys
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# 2. Get from firecrawl.dev → Dashboard → API Keys
FIRECRAWL_API_KEY=fc-REPLACE_ME

# 3. Get from hunter.io → Dashboard → API (free = 50 lookups/mo)
HUNTER_API_KEY=REPLACE_ME

# 4. Get from airtable.com/create/tokens (Personal Access Token)
AIRTABLE_API_KEY=patREPLACE_ME

# 5. Get from airtable.com/api → your workspace → ID starts with "wsp"
AIRTABLE_ORG_ID=wspREPLACE_ME

# 6. Filled automatically after running: python scripts/create_airtable_base.py
AIRTABLE_BASE_ID=appREPLACE_ME
