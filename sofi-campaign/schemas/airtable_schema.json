{
  "base_name": "SoFi Tournament Leads",
  "tables": [
    {
      "name": "Leads",
      "description": "All scraped + enriched restaurant leads near SoFi Stadium",
      "fields": [
        { "name": "Name",                   "type": "singleLineText",   "purpose": "Business name" },
        { "name": "Website",                "type": "url",              "purpose": "Business website" },
        { "name": "Email",                  "type": "email",            "purpose": "Decision maker email (Hunter enriched)" },
        { "name": "FirstName",              "type": "singleLineText",   "purpose": "Contact first name" },
        { "name": "LastName",               "type": "singleLineText",   "purpose": "Contact last name" },
        { "name": "Phone",                  "type": "phoneNumber",      "purpose": "Business phone" },
        { "name": "Address",                "type": "singleLineText",   "purpose": "Full address" },
        { "name": "PlaceId",                "type": "singleLineText",   "purpose": "Google Maps Place ID" },
        {
          "name": "Neighborhood",
          "type": "singleSelect",
          "options": ["Inglewood", "Westchester", "Culver City", "West LA", "Westwood", "Marina del Rey", "El Segundo", "Other"],
          "purpose": "Neighborhood for email personalization"
        },
        { "name": "GoogleRating",           "type": "number",           "purpose": "GBP rating (3.5 min filter)" },
        { "name": "ReviewCount",            "type": "number",           "purpose": "Number of reviews (20+ min filter)" },
        {
          "name": "Status",
          "type": "singleSelect",
          "options": ["not_contacted", "awaiting_reply", "booked_call", "closed", "declined", "unsubscribed"],
          "purpose": "Outreach pipeline stage"
        },
        { "name": "Audit_Completed",        "type": "checkbox",         "purpose": "Auto-checked by n8n after audit runs" },
        {
          "name": "Audit_Verdict",
          "type": "singleSelect",
          "options": ["tournament_ready", "partial", "not_ready"],
          "purpose": "Claude verdict — prioritize not_ready + partial"
        },
        { "name": "Audit_Priority_Score",   "type": "number",           "purpose": "0–100, higher = contact first" },
        { "name": "Personalization_Hook",   "type": "multilineText",    "purpose": "Paste into email {personalization_hook}" },
        { "name": "Highest_Leverage_Fix",   "type": "singleLineText",   "purpose": "The one fix — mention on call" },
        {
          "name": "Estimated_Traffic_Loss",
          "type": "singleSelect",
          "options": ["low", "medium", "high"],
          "purpose": "Used to weight outreach urgency"
        },
        { "name": "Ranking_Gap_1",          "type": "singleLineText",   "purpose": "Gap for email variant 2" },
        { "name": "Ranking_Gap_2",          "type": "singleLineText",   "purpose": "Gap for email variant 2" },
        { "name": "Ranking_Gap_3",          "type": "singleLineText",   "purpose": "Gap for email variant 2" },
        { "name": "Nationality_Angle",      "type": "singleLineText",   "purpose": "Diaspora match hook if applicable" },
        { "name": "Deal_Closed",            "type": "checkbox",         "purpose": "Manual — check when Stripe payment confirmed" },
        { "name": "Deal_Amount",            "type": "currency",         "purpose": "$997, $1497, or $1997" },
        { "name": "Delivery_Date",          "type": "date",             "purpose": "Promised delivery date" },
        { "name": "Notes",                  "type": "multilineText",    "purpose": "Call notes, objections, special requests" }
      ],
      "views": [
        {
          "name": "🎯 Outreach Queue",
          "type": "grid",
          "filter": "AND({Audit_Completed}=TRUE(), {Status}='not_contacted', {Audit_Verdict}!='tournament_ready')",
          "sort": [{ "field": "Audit_Priority_Score", "direction": "desc" }]
        },
        {
          "name": "📞 Booked Calls",
          "type": "grid",
          "filter": "{Status}='booked_call'"
        },
        {
          "name": "💰 Closed Deals",
          "type": "grid",
          "filter": "{Deal_Closed}=TRUE()"
        },
        {
          "name": "⏳ Awaiting Audit",
          "type": "grid",
          "filter": "{Audit_Completed}=FALSE()"
        }
      ]
    },
    {
      "name": "Replies",
      "description": "Inbound replies from Smartlead (or manual)",
      "fields": [
        { "name": "Lead",              "type": "linkedRecord",    "linkedTable": "Leads" },
        { "name": "Reply_Date",        "type": "date" },
        { "name": "Reply_Text",        "type": "multilineText" },
        {
          "name": "Category",
          "type": "singleSelect",
          "options": ["INTERESTED_BOOK_CALL", "OBJECTION_PRICE", "OBJECTION_TIMING", "ALREADY_DOING_IT", "REFERRAL", "UNSUBSCRIBE", "NOT_OWNER", "OTHER"]
        },
        { "name": "Sentiment",         "type": "number",          "purpose": "-1 to +1" },
        { "name": "Response_Sent",     "type": "checkbox" },
        {
          "name": "Next_Action",
          "type": "singleSelect",
          "options": ["send_loom", "book_call", "send_objection_handler", "follow_up", "archive"]
        }
      ]
    },
    {
      "name": "Closes",
      "description": "Confirmed deals — payment received",
      "fields": [
        { "name": "Lead",              "type": "linkedRecord",    "linkedTable": "Leads" },
        { "name": "Close_Date",        "type": "date" },
        { "name": "Deal_Size",         "type": "currency" },
        {
          "name": "Service_Tier",
          "type": "singleSelect",
          "options": ["Tournament_Audit", "Audit_Plus_Maintenance", "Full_Tournament_Run"]
        },
        { "name": "Payment_Received",  "type": "checkbox" },
        { "name": "Delivery_Date",     "type": "date" },
        {
          "name": "Delivery_Status",
          "type": "singleSelect",
          "options": ["pending", "in_progress", "completed"]
        },
        { "name": "Upsell_Offered",    "type": "checkbox" },
        { "name": "Notes",             "type": "multilineText" }
      ]
    }
  ]
}
